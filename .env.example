# --- Database ---
MONGO_URI="mongodb://user:password@host:port/?authSource=admin&directConnection=true"

# --- LLM Providers ---
NVIDIA_MOONSHOT_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_KEY="nvapi-YOUR_NVIDIA_KEY"
GEMINI_KEY="YOUR_GEMINI_API_KEY"
OPENROUTER_API_KEY="sk-or-v1-YOUR_OPENROUTER_KEY"
LLM_MODEL="moonshotai/kimi-k2"

# --- Integrations ---
TELEGRAM_BOT_API="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
N8N_URL="https://n8n.yourdomain.com"

# --- Google Workspace (gogcli) ---
# Used for Gmail and Calendar access
GMAIL_GOOGLE="your.email@gmail.com"
CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# --- Web App Authentication ---
USER_EMAIL="admin@yourdomain.com"
USER_PASSWORD="YOUR_ADMIN_PASSWORD"
